<UserControl x:Class="POET.TakeTestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
 
        <UserControl.Resources>
            <Style x:Key="LevelContainer" TargetType="Border">
                <Setter Property="Background" Value="White"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="20"/>
                <Setter Property="Margin" Value="10"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TestButton" TargetType="Button">
                <Setter Property="Background" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="15"/>
                <Setter Property="Margin" Value="5"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#F5F5F5"/>
                        <Setter Property="Foreground" Value="DodgerBlue"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" 
        Style="{StaticResource BackButton}"
        Click="BtnBack_Click"
        Width="50"
        Height="30"
        HorizontalAlignment="Right"/>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Test Selection Area -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Level 1 - Beginner -->
                    <Border Style="{StaticResource LevelContainer}">
                        <StackPanel>
                            <TextBlock Text="Level 1 - Beginner" 
                                 FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Button Content="Test 1: Basic Grammar" 
                              Style="{StaticResource TestButton}"
                              Tag="1" Click="TestButton_Click"/>
                            <Button Content="Test 2: Simple Tenses" 
                              Style="{StaticResource TestButton}"
                              Tag="2" Click="TestButton_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Level 2 - Intermediate -->
                    <Border Style="{StaticResource LevelContainer}">
                        <StackPanel>
                            <TextBlock Text="Level 2 - Intermediate" 
                                 FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Button Content="Test 1: Complex Sentences" 
                              Style="{StaticResource TestButton}"
                              Tag="3" Click="TestButton_Click"/>
                            <Button Content="Test 2: Advanced Vocabulary" 
                              Style="{StaticResource TestButton}"
                              Tag="4" Click="TestButton_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Level 3 - Advanced -->
                    <Border Style="{StaticResource LevelContainer}">
                        <StackPanel>
                            <TextBlock Text="Level 3 - Advanced" 
                                 FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                            <Button Content="Test 1: Business English" 
                              Style="{StaticResource TestButton}"
                              Tag="5" Click="TestButton_Click"/>
                            <Button Content="Test 2: Academic Writing" 
                              Style="{StaticResource TestButton}"
                              Tag="6" Click="TestButton_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Bottom Section -->
            <Border Grid.Row="1" Background="#F8F9FA" Padding="20" Margin="0,60,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Random Test"
                      Style="{StaticResource NavButton}"
                      Click="RandomTest_Click"
                      Padding="20,10"  
                      FontWeight="Bold"/>
                    <TextBlock Text="Want more tests? Join a class!" 
                         FontSize="16" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button Content="Join Class" 
                      Style="{StaticResource NavButton}"
                      Click="JoinClass_Click"
                      Padding="20,10"
                      FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>