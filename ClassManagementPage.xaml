<UserControl x:Class="POET.ClassManagementPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POET"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <DataGrid x:Name="classesGrid" 
                AutoGenerateColumns="False"
                IsReadOnly="True">
            <DataGrid.Columns>
                <!-- Class Name -->
                <DataGridTextColumn Header="Class Name"
                                    FontSize="17"
                                    Binding="{Binding ClassName}" 
                                    Width="130"/>

                <!-- Class Code -->
                <DataGridTextColumn Header="Class Code"
                                    FontSize="17"
                                    Binding="{Binding ClassCode}" 
                                    Width="130"/>

                <!-- Teacher -->
                <DataGridTextColumn Header="Teacher" 
                                    FontSize="17"
                                    Binding="{Binding Teacher.Username}" 
                                    Width="130"/>

                <!-- Actions -->
                <DataGridTemplateColumn Header="Actions" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <!-- View Participants -->
                                <Button Content="View Participants" 
                                      Click="ViewParticipants_Click"
                                      Tag="{Binding ClassId}"
                                      Style="{StaticResource NavButton}"
                                      Margin="5"/>

                                <!-- Delete Class -->
                                <Button Content="Delete Class" 
                                      Click="DeleteClass_Click"
                                      Tag="{Binding ClassId}"
                                      Style="{StaticResource DangerButton}"
                                      Margin="5"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
