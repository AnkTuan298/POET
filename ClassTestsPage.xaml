<UserControl x:Class="POET.ClassTestsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:System.Windows;assembly=PresentationCore">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- No Class Warning -->


        <!-- Class Tests List -->
        <ItemsControl Grid.Row="0" ItemsSource="{Binding Tests}"
                    Visibility="{Binding HasClass, Converter={StaticResource BoolToVis}}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding TestName}" 
                          Tag="{Binding TestId}"
                          Click="Test_Click"
                          Style="{StaticResource TestButton}"
                          Margin="5"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Back Button -->
        <Button Grid.Row="1" Content="Back" 
              Style="{StaticResource NavButton}"
              Click="BtnBack_Click"
              HorizontalAlignment="Left"/>
    </Grid>
</UserControl>