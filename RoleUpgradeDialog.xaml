<Window x:Class="POET.RoleUpgradeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upgrade Role" 
        Width="300" 
        Height="200"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">
    <StackPanel Margin="15" VerticalAlignment="Center">
        <TextBlock Text="Select new role:" Margin="0,0,0,10" FontWeight="Bold"/>
        <ComboBox x:Name="cmbRoles">
            <ComboBoxItem Content="Student"/>
            <ComboBoxItem Content="Teacher"/>
            <ComboBoxItem Content="Admin"/>
        </ComboBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Cancel" Click="Cancel_Click" Width="80" Margin="0,0,10,0"/>
            <Button Content="Confirm" Click="Confirm_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>