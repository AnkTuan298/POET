<UserControl x:Class="POET.ViewStudentProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:POET"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Search -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Back button -->
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBox x:Name="txtSearch"
                     Width="200"
                     Margin="0,0,10,0"
                     TextChanged="TxtSearch_TextChanged"/>
            <ComboBox x:Name="cmbSearchMode"
                      Width="120"
                      SelectedIndex="0">
                <ComboBoxItem Content="By Name"/>
                <ComboBoxItem Content="By Test"/>
            </ComboBox>
        </StackPanel>

        <!-- Student progress list -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="progressListControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="LightGray" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="16"
                                           Text="{Binding StudentName}" />

                                <ItemsControl ItemsSource="{Binding ScoreList}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="14" Margin="5,0,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Back button bottom left -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button Content="Back"
                    Click="BtnBack_Click"
                    Width="100"
                    Height="35"
                    Background="#2196F3" Foreground="White" />
        </StackPanel>
    </Grid>
</UserControl>
