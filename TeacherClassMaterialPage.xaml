<UserControl x:Class="POET.TeacherClassMaterialPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="600">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- DataGrid hiển thị danh sách material -->
        <DataGrid x:Name="materialGrid"
          AutoGenerateColumns="False"
          HeadersVisibility="Column"
          SelectionMode="Single"
          CanUserAddRows="False"
          IsReadOnly="True"
          Grid.Row="0"
          Margin="0,0,0,10"
          FontSize="14">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Material Name" Binding="{Binding Name}" Width="2*" />
                <DataGridTextColumn Header="Material Link" Binding="{Binding Url}" Width="3*" />
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="1">
            <!-- Nút Back bên trái -->
            <Button x:Name="btnBack" Content="Back" Width="100" HorizontalAlignment="Left" Margin="5" Click="BtnBack_Click" Background="DodgerBlue" Foreground="White" FontSize="15"/>

            <!-- Các nút điều khiển -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnAdd" Content="Add" Width="100" Margin="5" Click="BtnAdd_Click" Background="DodgerBlue" Foreground="White" FontSize="15"/>
            <Button x:Name="btnEdit" Content="Edit" Width="100" Margin="5" Click="BtnEdit_Click" Background="DodgerBlue" Foreground="White" FontSize="15"/>
            <Button x:Name="btnDelete" Content="Delete" Width="100" Margin="5" Click="BtnDelete_Click" Background="DodgerBlue" Foreground="White" FontSize="15"/>
        </StackPanel>
        </Grid>
    </Grid>
</UserControl>
