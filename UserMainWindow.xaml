<Window x:Class="POET.Views.UserMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POET - Student Dashboard" 
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        KeyDown="Window_KeyDown">

    <Border Background="White" 
            CornerRadius="0" 
            BorderThickness="1"
            BorderBrush="#FFE0E0E0">

        <Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="8*"/>
                </Grid.ColumnDefinitions>

                <!-- ========== Part 1: Navigation Panel ========== -->
                <Border Grid.Column="0" 
                    Background="#FFF5F5F5"
                    CornerRadius="10">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel x:Name="SidebarPanel">
                            <TextBlock
                             x:Name="txtPoetLogo"
                             Text="POET" 
                             FontSize="35"
                             FontWeight="Bold"
                             Foreground="Black"
                             Margin="20,30,20,40"
                             Cursor="Hand"
                             MouseDown="PoetLogo_MouseDown"/>
                            <Button x:Name="btnProfile" 
                            Content="Profile"
                            Style="{StaticResource NavButton}"
                            Click="NavButton_Click"/>

                                <Button x:Name="btnTakeTest" 
                            Content="Take a Test"
                            Style="{StaticResource NavButton}"
                            Click="NavButton_Click"/>


                            <Button x:Name="btnClass" 
                            Content="Class"
                            Style="{StaticResource NavButton}"
                            Click="Class_Click"/>

                            <!-- Add submenu -->
                            <StackPanel x:Name="classSubMenu" 
                            Visibility="Collapsed"
                            Margin="20,0,0,0">  
                                <Button x:Name="btnYourClass"
                            FontSize="15"
                            Content="- Your Class"
                            Style="{StaticResource NavButton}"
                            Click="ClassSubMenu_Click"/>
                                <Button x:Name="btnClassTests"
                            FontSize="15"
                            Content="- Class Tests"
                            Style="{StaticResource NavButton}"
                            Click="ClassSubMenu_Click"/>
                                <Button x:Name="btnJoinClass"
                            FontSize="15"            
                            Content="- Join Class"
                            Style="{StaticResource NavButton}"
                            Click="ClassSubMenu_Click"/>
                            </StackPanel>

                            <Button x:Name="btnRoleUpgrade" 
                            Content="Role Upgrade"
                            Style="{StaticResource NavButton}"
                            Click="RoleUpgrade_Click"
                            Margin="0,5,0,0"/>

                            <Button x:Name="btnLogout"
                            Content="Log Out"
                            Style="{StaticResource NavButton}"
                            Click="BtnLogout_Click"
                            Margin="0,20,0,0"/>
                            
                        </StackPanel>
                        <Border Grid.Row="1" 
                         BorderBrush="#FFE0E0E0"
                         BorderThickness="0,1,0,0"
                         Margin="20,10"
                         Padding="0,10">
                        <TextBlock TextWrapping="Wrap"
                         TextAlignment="Center"
                         HorizontalAlignment="Center"
                         MaxWidth="200">
                        <Run Text="Contact for help:" FontWeight="SemiBold"/>
                        <LineBreak/>
                        <Run Text="tuananhtrinh29823@gmail.com"/>
                        </TextBlock>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Image Source="/Mics/Background.jpg"
                 Stretch="UniformToFill">
                    </Image>



                    <Border Margin="65,40"
                    BorderBrush="Black"
                    BorderThickness="2"
                    CornerRadius="10"
                    Background="Transparent"
                    ClipToBounds="True">

                        <Grid>
                            <Rectangle RadiusX="10" RadiusY="10">
                                <Rectangle.Fill>
                                    <SolidColorBrush Color="White" Opacity="0.96"/>
                                </Rectangle.Fill>
                                <Rectangle.Effect>
                                    <BlurEffect Radius="2"/>
                                </Rectangle.Effect>
                            </Rectangle>


                            <!-- Part 2: Content Area -->
                            <Frame x:Name="contentFrame" 
                 Grid.Column="1"
                 NavigationUIVisibility="Hidden"
                 Background="Transparent">
                            </Frame>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" 
                      HorizontalAlignment="Right" 
                      VerticalAlignment="Top"
                      Margin="0,33,15,0"
                      Panel.ZIndex="2">
                    <!-- Ensure it's on top -->
                    <!-- Minimize Button -->
                    <Button x:Name="btnMinimize" 
                      Style="{StaticResource WindowControlButton}"
                      Click="BtnMinimize_Click"
                      ToolTip="Minimize">
                        <TextBlock Text="─" 
                             FontSize="14"
                             FontWeight="Bold"
                             Foreground="#FF444444"/>
                    </Button>

                    <!-- Close Button -->
                    <Button x:Name="btnClose" 
                      Style="{StaticResource WindowControlButton}"
                      Click="BtnClose_Click"
                      Margin="10,0,0,0"
                      ToolTip="Close">
                        <TextBlock Text="✕" 
                             FontSize="14"
                             Foreground="#FF444444"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Grid>
    </Border>
</Window>