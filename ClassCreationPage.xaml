<UserControl x:Class="POET.ClassCreationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:POET"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" 
                Style="{StaticResource BackButton}"
                Click="BtnBack_Click"
                HorizontalAlignment="Right"/>

        <Grid Grid.Row="1" VerticalAlignment="Center">
            <!-- Display based on whether teacher has a class -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="txtExistingClass" 
                     Text="You already own a class"
                     Visibility="Collapsed"
                     FontSize="24"
                     HorizontalAlignment="Center"/>
            <Button x:Name="btnDeleteClass"
                     Content="Delete Class"
                     Style="{StaticResource DangerButtoon}"
                     Margin="0,20"
                     Padding="20,10"
                     Click="DeleteClass_Click"
                     Visibility="Collapsed"/>
            </StackPanel>
            <!-- Class Creation Form -->
            <StackPanel x:Name="createClassPanel"
                      Visibility="Collapsed"
                      HorizontalAlignment="Center"
                      Width="300">
                <TextBlock Text="Create New Class" FontSize="20" Margin="0,0,0,20"/>

                <TextBox x:Name="txtClassName" 
                       Style="{StaticResource FormField}"
                       Tag="Class Name"/>

                <Button Content="Create Class" 
                      Click="CreateClass_Click"
                      Style="{StaticResource PrimaryButton}"
                      Margin="0,20"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
