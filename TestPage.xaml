<UserControl x:Class="POET.TestPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:POET"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Width="800" Height="600">

    <UserControl.Resources>
        <local:RadioButtonCheckedConverter x:Key="RadioConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Timer Header -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock x:Name="txtTimer" 
                         Foreground="White"
                         FontSize="20" FontWeight="Bold"
                         Text="15:00"/>
            </StackPanel>
        </Border>

        <!-- Questions Area -->
        <ScrollViewer Grid.Row="1" Padding="20" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="QuestionsItemsControl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,20" Padding="20"
                              Background="White" CornerRadius="5"
                              BorderBrush="#EEEEEE" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="{Binding QuestionText}"
                                         FontSize="16" FontWeight="SemiBold"
                                         TextWrapping="Wrap"
                                         Margin="0,0,0,15"/>

                                <RadioButton GroupName="{Binding QuestionId}" 
                                    Content="{Binding OptionA}"
             IsChecked="{Binding UserAnswer, Converter={StaticResource RadioConverter}, ConverterParameter=A}"
             Margin="0,5"/>

                                    <RadioButton GroupName="{Binding QuestionId}" 
             Content="{Binding OptionB}"
             IsChecked="{Binding UserAnswer, Converter={StaticResource RadioConverter}, ConverterParameter=B}"
             Margin="0,5"/>

                                    <RadioButton GroupName="{Binding QuestionId}" 
             Content="{Binding OptionC}"
             IsChecked="{Binding UserAnswer, Converter={StaticResource RadioConverter}, ConverterParameter=C}"
             Margin="0,5"/>

                                    <RadioButton GroupName="{Binding QuestionId}" 
             Content="{Binding OptionD}"
             IsChecked="{Binding UserAnswer, Converter={StaticResource RadioConverter}, ConverterParameter=D}"
             Margin="0,5"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Submit Button -->
        <Button Grid.Row="2" Content="SUBMIT TEST"
              Click="SubmitTest_Click"
              Background="#2196F3" Foreground="White"
              FontSize="16" FontWeight="Bold"
              Padding="30,15" Margin="20"
              HorizontalAlignment="Center"/>
    </Grid>
</UserControl>