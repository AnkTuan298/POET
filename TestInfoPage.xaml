<UserControl x:Class="POET.TestInfoPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="600" Height="400">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" 
        Style="{StaticResource BackButton}"
        Click="BtnBack_Click"
        Width="50"
        Height="30"
        VerticalAlignment="Top"
        HorizontalAlignment="Right"/>   

        <Grid Margin="30" Grid.Row="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Test Name -->
        <TextBlock Text="{Binding TestName}" 
                 Grid.Row="0"
                 FontSize="28" FontWeight="Bold"
                 Margin="0,0,0,20"
                 HorizontalAlignment="Center"/>

        <!-- Level -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Level: " 
                     FontSize="20" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Level.LevelName}" 
                     FontSize="20"/>
        </StackPanel>

        <!-- Time Limit -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Time Limit: " 
                     FontSize="20" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
            <TextBlock Text="15:00" 
                     FontSize="20"/>
        </StackPanel>

        <!-- Questions -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,30">
            <TextBlock Text="Questions: " 
                     FontSize="20" FontWeight="SemiBold"
                     VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Questions.Count}" 
                     FontSize="20"/>
        </StackPanel>

        <!-- Start Button -->
        <Button Grid.Row="5" Content="START TEST" 
                Click="StartTest_Click"
                Background="#2196F3" Foreground="White"
                FontSize="22" FontWeight="Bold"
                Padding="40,15"
                HorizontalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>