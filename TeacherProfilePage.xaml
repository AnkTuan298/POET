<UserControl x:Class="POET.TeacherProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:POET"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="UserControl_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Back Button -->
        <Button Grid.Row="0" 
                Style="{StaticResource BackButton}"
                Click="BtnBack_Click"
                HorizontalAlignment="Right"/>

        <Grid Grid.Row="1" VerticalAlignment="Center">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="400"/>
                </Grid.ColumnDefinitions>

                <!-- Username -->
                <TextBlock Text="Username:" Grid.Row="0" Grid.Column="0"
                         FontSize="18" FontWeight="Bold" Margin="10"/>
                <TextBlock Text="{Binding Username}" Grid.Row="0" Grid.Column="1"
                         FontSize="18" Margin="10"/>

                <!-- Class (Non-editable) -->
                <TextBlock Text="Class:" Grid.Row="1" Grid.Column="0"
                         FontSize="18" FontWeight="Bold" Margin="10"/>
                <TextBlock x:Name="txtClassName" Grid.Row="1" Grid.Column="1"
                         FontSize="18" Margin="10" FontStyle="Italic"/>

                <!-- Name -->
                <TextBlock Text="Full Name:" Grid.Row="2" Grid.Column="0"
                         FontSize="18" FontWeight="Bold" Margin="10"/>
                <TextBox Text="{Binding Profile.Name}" Grid.Row="2" Grid.Column="1"
                       FontSize="18" Margin="10" Padding="8"/>

                <!-- Email -->
                <TextBlock Text="Email:" Grid.Row="3" Grid.Column="0"
                         FontSize="18" FontWeight="Bold" Margin="10"/>
                <TextBox Text="{Binding Profile.Email}" Grid.Row="3" Grid.Column="1"
                       FontSize="18" Margin="10" Padding="8"/>

                <!-- Phone -->
                <TextBlock Text="Phone:" Grid.Row="4" Grid.Column="0"
                         FontSize="18" FontWeight="Bold" Margin="10"/>
                <TextBox Text="{Binding Profile.PhoneNumber}" Grid.Row="4" Grid.Column="1"
                       FontSize="18" Margin="10" Padding="8"/>

                <!-- Update Button -->
                <Button Content="Update Profile" Grid.Row="5" Grid.ColumnSpan="2"
                      Style="{StaticResource PrimaryButton}"
                      Click="BtnUpdate_Click"
                      Margin="0,20"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
