<Window x:Class="POET.ScrollableMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Results" 
        Width="400" 
        Height="300"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <ScrollViewer>
            <TextBlock x:Name="txtMessage" Margin="10" TextWrapping="Wrap" FontSize="15"/>
        </ScrollViewer>
        <Button Content="OK" Click="Button_Click" Width="75" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10"/>
    </Grid>
</Window>