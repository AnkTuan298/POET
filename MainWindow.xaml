<Window x:Class="POET.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POET - Login"
        Width="400" Height="500"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStyle="None"
        KeyDown="Window_KeyDown">

    <Border Background="White" CornerRadius="10" Padding="10">
        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            
            <!-- Success Screen -->
            <Grid Name="SuccessMessage" Grid.Row="1" Opacity="0" Visibility="Collapsed">
                <TextBlock Text="Login Successful ✅" 
               FontSize="24" 
               FontWeight="Bold"
               Foreground="ForestGreen"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>

            <!-- Welcome Screen -->
            <Grid Name="WelcomeScreen" Grid.Row="1" VerticalAlignment="Center">
                <TextBlock x:Name="WelcomeText" 
               Text="Welcome to POET" 
               FontSize="24" 
               FontWeight="Bold" 
               HorizontalAlignment="Center">
                    <TextBlock.RenderTransform>
                        <TranslateTransform x:Name="WelcomeTransform" />
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>

            <!-- Close Button -->
            <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="Hand"
                  MouseEnter="CloseButton_MouseEnter" MouseLeave="CloseButton_MouseLeave" MouseDown="CloseButton_MouseDown">
                <Rectangle x:Name="CloseButtonBackground" Width="40" Height="40" Fill="Transparent"/>
                <TextBlock x:Name="CloseButtonIcon" Text="✖" Foreground="Black" FontSize="16" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Login Screen -->
            <Grid Name="LoginScreen" Grid.Row="1" Opacity="0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                    <TextBlock Text="Login" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <Grid Width="250" Height="35">
                        <TextBlock x:Name="txtUsernamePlaceholder" 
                             Text="Enter Username" 
                             FontSize="16"
                             Foreground="Gray"
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Left"
                             Padding="10,0,0,0"
                             IsHitTestVisible="False"/>
                        <TextBox x:Name="txtUsername"
                             FontSize="16"
                             Width="250" Height="35"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             BorderThickness="0,0,0,1"
                             BorderBrush="Gray"
                             Padding="9,0,0,0"
                             GotFocus="txtUsername_GotFocus"
                             LostFocus="txtUsername_LostFocus"
                             TextChanged="txtUsername_TextChanged"/>
                    </Grid>

                    <Grid Width="250" Height="35" Margin="0,10,0,0">
                        <TextBlock x:Name="txtPasswordPlaceholder" 
                             Text="Enter Password" 
                             FontSize="16" Foreground="Gray"
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Left"
                             Padding="10,0,0,0"
                             IsHitTestVisible="False"/>
                        <PasswordBox x:Name="txtPassword"
                             FontSize="16"
                             Width="250" Height="35"
                             VerticalContentAlignment="Center"
                             BorderThickness="0,0,0,1"
                             BorderBrush="Gray"
                             Background="Transparent"
                             Padding="9,0,0,0"
                             PasswordChanged="txtPassword_PasswordChanged"/>
                    </Grid>

                    <Button x:Name="btnLogin" Content="Login" Width="250" Height="40" Background="DodgerBlue" Foreground="White" 
                            FontSize="16" FontWeight="Bold" Margin="0,20,0,0"
                            Click="Login_Click"/>

                    <TextBlock Text="Don't have an account? Register" Foreground="Gray" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,10,0,0" Cursor="Hand"
                               MouseDown="ShowRegisterScreen"/>

                    <TextBlock Text="Forgot Password?" Foreground="Gray" FontSize="12" 
                               HorizontalAlignment="Center" Margin="0,10,0,0" Cursor="Hand"
                               MouseDown="ForgotPassword_Click"/>

                </StackPanel>
            </Grid>

            <!-- Register Screen (Hidden) -->
            <Grid Name="RegisterScreen" Grid.Row="1" Opacity="0" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                    <TextBlock Text="Register" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <Grid Width="250" Height="35">
                        <TextBlock x:Name="txtRegisterUsernamePlaceholder" 
                        Text="Enter Username" FontSize="16" Foreground="Gray"
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Left"
                        Padding="10,0,0,0"
                        IsHitTestVisible="False"/>
                        <TextBox x:Name="txtRegisterUsername" 
                        FontSize="16"
                        Width="250" Height="35"
                        Background="Transparent" 
                        VerticalContentAlignment="Center"
                        BorderThickness="0,0,0,1"
                        BorderBrush="Gray"
                        Padding="9,0,0,0"
                        GotFocus="txtRegisterUsername_GotFocus"
                        LostFocus="txtRegisterUsername_LostFocus"
                        TextChanged="txtRegisterUsername_TextChanged"/>
                    </Grid>

                    <Grid Width="250" Height="35" Margin="0,10,0,0">
                        <TextBlock x:Name="txtRegisterPasswordPlaceholder" 
                        Text="Enter Password" 
                        FontSize="16" Foreground="Gray"
                        VerticalAlignment="Center" HorizontalAlignment="Left"
                        Padding="10,0,0,0"
                        IsHitTestVisible="False"/>
                        <PasswordBox x:Name="txtRegisterPassword" 
                        FontSize="16" 
                        Width="250" Height="35"
                        Background="Transparent"
                        BorderThickness="0,0,0,1"
                        BorderBrush="Gray"
                        VerticalContentAlignment="Center"
                        Padding="9,0,0,0"
                        PasswordChanged="txtRegisterPassword_PasswordChanged"/>
                    </Grid>

                    <Grid Width="250" Height="35" Margin="0,10,0,0">
                        <TextBlock x:Name="txtConfirmRegisterPasswordPlaceholder" 
                        Text="Re-Enter Password" 
                        FontSize="16" Foreground="Gray"
                        VerticalAlignment="Center" HorizontalAlignment="Left"
                        Padding="10,0,0,0"
                        IsHitTestVisible="False"/>
                        <PasswordBox x:Name="txtConfirmRegisterPassword" 
                        FontSize="16" 
                        Width="250" Height="35"
                        Background="Transparent"
                        BorderThickness="0,0,0,1"
                        BorderBrush="Gray"
                        VerticalContentAlignment="Center"
                        Padding="9,0,0,0"
                        PasswordChanged="txtConfirmRegisterPassword_PasswordChanged"/>
                    </Grid>

            <Button Content="Register" Width="250" Height="40" Background="DodgerBlue"
                Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,20,0,0"
                Click="Register_Click" x:Name="btnRegister"/>

                    <TextBlock Text="Back to Login" Foreground="Gray" FontSize="12" HorizontalAlignment="Center"
                   Margin="0,10,0,0" Cursor="Hand" MouseDown="BackToLogin_Click"/>
                </StackPanel>
            </Grid>

            <!-- Forgot Password Screen (Hidden) -->
            <Grid Name="ForgotPasswordScreen" Grid.Row="1" Opacity="0" Visibility="Collapsed">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
                    <TextBlock Text="Reset Password" FontSize="22" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

                    <Grid Width="250" Height="35">
                        <TextBlock x:Name="txtResetUsernamePlaceholder" Text="Enter Username"
                                   FontSize="16" Foreground="Gray"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Padding="10,0,0,0" IsHitTestVisible="False"/>
                        <TextBox x:Name="txtResetUsername" 
                                   FontSize="16"
                                   Width="250" Height="35" 
                                   Background="Transparent"
                                   VerticalContentAlignment="Center"
                                   BorderThickness="0,0,0,1"
                                   BorderBrush="Gray"
                                   Padding="9,0,0,0"
                                   GotFocus="txtResetUsername_GotFocus" 
                                   LostFocus="txtResetUsername_LostFocus"
                                   TextChanged="txtResetUsername_TextChanged"/>
                    </Grid>

                    <Grid Width="250" Height="35" Margin="0,10,0,0">
                        <TextBlock x:Name="txtNewPasswordPlaceholder" Text="Enter New Password"
                                   FontSize="16" Foreground="Gray"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Padding="10,0,0,0"
                                   IsHitTestVisible="False"/>
                        <PasswordBox x:Name="txtNewPassword" FontSize="16"
                                   Width="250" Height="35"
                                   Background="Transparent"
                                   VerticalContentAlignment="Center"
                                   BorderThickness="0,0,0,1"
                                   BorderBrush="Gray"
                                   Padding="9,0,0,0"
                                   GotFocus="txtNewPassword_GotFocus"
                                   LostFocus="txtNewPassword_LostFocus"
                                   PasswordChanged="txtNewPassword_PasswordChanged"/>
                    </Grid>

                    <Grid Width="250" Height="35" Margin="0,10,0,0">
                        <TextBlock x:Name="txtConfirmPasswordPlaceholder"
                                   Text="Confirm New Password"
                                   FontSize="16"
                                   Foreground="Gray"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Padding="10,0,0,0"
                                   IsHitTestVisible="False"/>
                        <PasswordBox x:Name="txtConfirmPassword" FontSize="16"
                                   Width="250" Height="35"
                                   Background="Transparent"
                                   VerticalContentAlignment="Center"
                                   BorderThickness="0,0,0,1"
                                   BorderBrush="Gray"
                                   Padding="9,0,0,0"
                                   GotFocus="txtConfirmPassword_GotFocus"
                                   LostFocus="txtConfirmPassword_LostFocus"
                                   PasswordChanged="txtConfirmPassword_PasswordChanged"/>
                    </Grid>
                    
                    <Button Content="Change Password" Width="250" Height="40" Background="DodgerBlue"
                            Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,20,0,0"
                            Click="ChangePassword_Click" x:Name="btnChangePassword"/>

                    <TextBlock Text="Back to Login" Foreground="Gray" FontSize="12" HorizontalAlignment="Center"
                               Margin="0,10,0,0" Cursor="Hand" MouseDown="BackToLogin_Click"/>
                </StackPanel>
            </Grid>


            <!-- Under Developement!!! -->

        </Grid>
    </Border>
</Window>
