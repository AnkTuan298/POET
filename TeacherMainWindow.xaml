<Window x:Class="POET.TeacherMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="POET - Teacher Dashboard" 
        Width="1200" Height="700"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="0" BorderThickness="1" BorderBrush="#FFE0E0E0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <!-- Navigation Panel -->
                <ColumnDefinition Width="8*"/>
                <!-- Content Area -->
            </Grid.ColumnDefinitions>

            <!-- Left Navigation Panel -->
            <Border Grid.Column="0" Background="#FFF5F5F5">
                <Grid>
                    <StackPanel>
                    <!-- POET Logo -->
                    <TextBlock Text="POET" 
                             FontSize="35" FontWeight="Bold"
                             Margin="20,30,20,40"
                             Cursor="Hand"
                             MouseDown="PoetLogo_MouseDown"/>

                    <Button x:Name="btnProfile" 
                    Content="Profile"
                    Style="{StaticResource NavButton}"
                    Click="Profile_Click"
                    Margin="0,10,0,0"/>

                        <!-- Class Button (with Submenu) -->
                    <Button x:Name="btnClass" 
                          Content="Class"
                          Style="{StaticResource NavButton}"
                          Click="Class_Click"/>

                    <!-- Submenu (Students/Tests) -->
                        <StackPanel x:Name="subMenuPanel" Visibility="Collapsed" x:FieldModifier="internal">
                        <Button x:Name="btnStudents"
                              FontSize="14"
                              Content="- Your Class"
                              Style="{StaticResource NavButton}"
                              Click="SubMenu_Click"/>
                        <Button x:Name="btnTests"
                              FontSize="14"
                              Content="- Tests"
                              Style="{StaticResource NavButton}"
                              Click="SubMenu_Click"/>
                            <Button x:Name="btnCreateClass" 
                              FontSize="14"
                              Content="- Create Class"
                              Style="{StaticResource NavButton}"
                              Click="SubMenu_Click"/>
                    </StackPanel>

                    <!-- Logout -->
                    <Button x:Name="btnLogout"
                          Content="Log Out"
                          Style="{StaticResource NavButton}"
                          Click="BtnLogout_Click"
                          Margin="0,20,0,0"/>
                </StackPanel>
                    <Border Grid.Row="1" 
                            VerticalAlignment="Bottom"
                            BorderBrush="#FFE0E0E0" 
                            BorderThickness="0,1,0,0" 
                            Margin="20,10" 
                            Padding="0,10">         
                        <TextBlock TextWrapping="Wrap" 
                            TextAlignment="Center" 
                            HorizontalAlignment="Center" 
                            MaxWidth="200">
                            <Run Text="Contact for help:" FontWeight="SemiBold"/>
                            <LineBreak/>
                            <Run Text="tuananhtrinh29823@gmail.com"/>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>
            
            

            <!-- Content Area -->
            <Grid Grid.Column="1">
                <Image Source="D:\Malice Binah\.1\PRN212\Prject\POET\Mics\Background3.jpg"
                     Stretch="UniformToFill"/>

                <Border Margin="65,40" BorderBrush="Black" BorderThickness="2" CornerRadius="10" Background="Transparent">
                    <Grid>
                        <Rectangle RadiusX="10" RadiusY="10">
                            <Rectangle.Fill>
                                <SolidColorBrush Color="White" Opacity="0.96"/>
                            </Rectangle.Fill>
                            <Rectangle.Effect>
                                <BlurEffect Radius="2"/>
                            </Rectangle.Effect>
                        </Rectangle>
                        <Frame x:Name="contentFrame" NavigationUIVisibility="Hidden" Background="Transparent"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- Window Controls (Minimize/Close) -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,33,15,0">
                <Button x:Name="btnMinimize" Style="{StaticResource WindowControlButton}" Click="BtnMinimize_Click">
                    <TextBlock Text="─" FontSize="14" FontWeight="Bold" Foreground="#FF444444"/>
                </Button>
                <Button x:Name="btnClose" Style="{StaticResource WindowControlButton}" Click="BtnClose_Click" Margin="10,0,0,0">
                    <TextBlock Text="✕" FontSize="14" Foreground="#FF444444"/>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>