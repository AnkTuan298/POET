<Window x:Class="POET.Views.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message"
        Width="350" Height="320"
        WindowStartupLocation="Manual"
        Top="300"
        Left="594"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="White" CornerRadius="10" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Just A Custom MessageBox -->
            <TextBlock x:Name="txtMessage" Text="Message" 
                       FontSize="16" FontWeight="Bold" 
                       TextAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0"/>

            <!-- OK Button -->
            <Button x:Name="btnOK" Content="OK" Width="80" Height="35"
                    Background="DodgerBlue" Foreground="White" 
                    FontSize="14" FontWeight="Bold" 
                    HorizontalAlignment="Center"
                    Click="btnOK_Click" />
        </Grid>
    </Border>
</Window>
