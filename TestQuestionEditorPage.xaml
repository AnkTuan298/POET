<UserControl x:Class="POET.TestQuestionEditorPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:POET"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <x:Array x:Key="AnswerOptions" Type="sys:String">
            <sys:String>A</sys:String>
            <sys:String>B</sys:String>
            <sys:String>C</sys:String>
            <sys:String>D</sys:String>
        </x:Array>
    </UserControl.Resources>

    <Grid Margin="20">
        
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button x:Name="btnBack" 
                        Grid.Row="0"
                        Style="{StaticResource BackButton}"
                        Click="BtnBack_Click"
                        Width="50"
                        Height="30"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        ToolTip="Back to Home"/>
                
                <Button Content="Add New Question" 
                        Click="AddQuestion_Click"
                        Style="{StaticResource NavButton}"
                        Margin="0,0,10,0"/>
                
                <Button Content="Import Questions from File" 
                        Click="ImportQuestions_Click"
                        Style="{StaticResource NavButton}"
                        ToolTip="Format: Question||A||B||C||D||CorrectAnswer"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="400">
                <ItemsControl x:Name="questionsItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" Padding="10" 
                                  Background="#FFF5F5F5" CornerRadius="5">
                                <StackPanel>
                                    <TextBox Text="{Binding QuestionText, UpdateSourceTrigger=PropertyChanged}" 
                                           Margin="0,0,0,10"
                                           FontSize="14"
                                           ToolTip="Enter question text"
                                           Background="{Binding QuestionText, Converter={StaticResource RequiredFieldConverter}}"/>

                                    <Grid Margin="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Text="{Binding OptionA}" Grid.Column="0" Margin="5"
                                               ToolTip="Option A"/>
                                        <TextBox Text="{Binding OptionB}" Grid.Column="1" Margin="5"
                                               ToolTip="Option B"/>
                                        <TextBox Text="{Binding OptionC}" Grid.Column="2" Margin="5"
                                               ToolTip="Option C"/>
                                        <TextBox Text="{Binding OptionD}" Grid.Column="3" Margin="5"
                                               ToolTip="Option D"/>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox 
                                        SelectedValue="{Binding CorrectOption, Mode=TwoWay}"
                                        ItemsSource="{Binding Source={StaticResource AnswerOptions}}"
                                        DisplayMemberPath="."
                                        SelectedValuePath="."
                                        Margin="5" 
                                        Width="100"
                                        ToolTip="Select correct answer"
                                        FontSize="20"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center">
                                        </ComboBox>

                                        <Button Content="Delete" 
                                              Click="DeleteQuestion_Click"
                                              Tag="{Binding QuestionId}"
                                              Style="{StaticResource DangerButton}"
                                              Margin="5"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Content="Save All Changes" 
                    Click="SaveChanges_Click"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>